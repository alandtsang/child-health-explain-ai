page {
  background: #f8fafc;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.section {
  background: #ffffff;
  border: 1rpx solid #d7dee8;
  border-radius: 8rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.primary {
  background: #0f766e;
  color: #ffffff;
}

.muted {
  color: #64748b;
}

.field {
  background: #f8fafc;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  min-height: 84rpx;
  padding: 18rpx;
  width: 100%;
}
